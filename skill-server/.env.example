# ==============================================================================
# Cascade Predator — ERC-8183 Skill Server Environment
# Copy to .env and fill in your credentials.
# NEVER commit the real .env file.
# ==============================================================================

# Wallet — used for ERC-8004 registration and ERC-8183 provider role
# First run: set PRIVATE_KEY to import, then remove it — keystore is saved to ~/.bnbagent/wallets/
PRIVATE_KEY=0x...
WALLET_PASSWORD=your-secure-password-here

# Network: bsc-testnet (recommended — gas-free ERC-8004 registration via MegaFuel)
NETWORK=bsc-testnet

# This server's public URL — required by LocalStorageProvider to serve deliverables
# In development: use ngrok or similar to expose localhost
ERC8183_AGENT_URL=http://localhost:8003/erc8183

# Minimum acceptable payment per strategy signal job (in U token raw units, 18 decimals)
# 1 U token = 1_000_000_000_000_000_000
# Set to 0 for free/demo mode
ERC8183_SERVICE_PRICE=0

# CoinMarketCap API key (for live derivatives data)
# Get yours at: https://coinmarketcap.com/api/
CMC_API_KEY=your_cmc_api_key_here

# Google Gemini API key (for LLM signal confirmation)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Strategy parameters (all configurable — nothing hardcoded)
CASCADE_SCORE_THRESHOLD=70
TAKE_PROFIT_PCT=3.0
STOP_LOSS_PCT=1.5
TRADE_SIZE_PCT=10
EXIT_TIMEOUT_CANDLES=12

# Tokens to scan (comma-separated, must be in config/token-allowlist.json)
MONITORED_TOKENS=WBNB,CAKE,FLOKI,TWT,PENDLE
